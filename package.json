{
  "private": true,
  "scripts": {
    "dev": "node scripts/set-env.js dev && turbo run dev",
    "dev:qa": "node scripts/set-env.js qa && turbo run dev",
    "dev:prod": "node scripts/set-env.js prod && turbo run dev",
    "build": "node scripts/set-env.js prod && turbo run build",
    "env:dev": "node scripts/set-env.js dev",
    "env:qa": "node scripts/set-env.js qa",
    "env:prod": "node scripts/set-env.js prod",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/minimatch": "^6.0.0",
    "prettier": "^3.1.1",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": ">=18"
  },
  "name": "with-react-native-web",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
